# MongoDB Configuration
# MongoDB Atlas connection string for Eurobridge Language Institute
# Already configured in .env for production use
MONGODB_URI=mongodb+srv://eurobridge_db_user:2kvG03uD2mdun1Rv@eurobridgelanguageinsti.ufjkdkv.mongodb.net/?appName=EurobridgeLanguageInstitute

# Database name
MONGODB_DB_NAME=eurobridge

# JWT Configuration
# Generate a secure secret (minimum 32 characters recommended)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Server Configuration
PORT=5000

# CORS Configuration
# For local development: http://localhost:5173
# For Netlify production: your-frontend-domain.netlify.app
CORS_ORIGIN=http://localhost:5173

# Environment
NODE_ENV=development

